# FilmIntern Local Development
# Copy this file to .env and fill in your API keys

# AI Provider API Keys (optional - set the ones you use)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Ollama is auto-configured to reach host.docker.internal in Docker.
# Override only if running Ollama on a different host/port:
# OLLAMA_BASE_URL=http://host.docker.internal:11434/api

# Tip: After changing package.json dependencies, restart with:
#   docker compose up -V
# The -V flag recreates anonymous volumes (node_modules cache).
