FROM node:22-bookworm-slim
WORKDIR /app

RUN apt-get update && \
    apt-get install -y --no-install-recommends build-essential python3 && \
    rm -rf /var/lib/apt/lists/*

# Pre-create directories owned by node so npm install and next dev can write to them
RUN mkdir -p /app/node_modules /app/.next && chown node:node /app/node_modules /app/.next

# Run as node user (uid 1000) to avoid root-owned files on host bind mount
USER node

CMD ["sh", "-c", "npm install && npm run dev"]
